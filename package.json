{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "portfolio",
  "author": "Paul Barnes",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "GATSBY_TELEMETRY_DISABLED=1 GATSBY_FEEDBACK_DISABLED=1 gatsby develop",
    "start": "npm run develop",
    "build": "GATSBY_TELEMETRY_DISABLED=1 GATSBY_FEEDBACK_DISABLED=1 gatsby build",
    "deploy": "npm run build && AWS_SDK_LOAD_CONFIG=1 node scripts/deploy-s3.js",
    "serve": "gatsby serve",
    "clean": "GATSBY_TELEMETRY_DISABLED=1 GATSBY_FEEDBACK_DISABLED=1 gatsby clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "classnames": "^2.5.1",
    "gatsby": "^5.16.1",
    "gatsby-plugin-google-analytics": "^5.16.0",
    "gatsby-plugin-react-helmet": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-remark-prismjs": "^7.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-javascript-static-exports": "^5.14.0",
    "gatsby-transformer-json": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "gsap": "^3.15.0",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.70.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "gatsby-plugin-sass": "^6.16.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@ardatan/relay-compiler": {
      "immutable": "^3.8.3"
    },
    "@parcel/cache": "^2.16.4",
    "@parcel/core": "^2.16.4",
    "@parcel/fs": "^2.16.4",
    "@parcel/logger": "^2.16.4",
    "@parcel/package-manager": "^2.16.4",
    "@parcel/plugin": "^2.16.4",
    "@parcel/reporter-dev-server": "^2.16.4",
    "@parcel/types": "^2.16.4",
    "@parcel/utils": "^2.16.4",
    "@parcel/workers": "^2.16.4",
    "cookie": "^0.7.2",
    "file-type": "^22.0.1",
    "lodash": "^4.18.1",
    "path-to-regexp": "0.1.13",
    "postcss": "^8.5.14",
    "resolve-url-loader": "^5.0.0",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.5",
    "webpack": "^5.106.2"
  }
