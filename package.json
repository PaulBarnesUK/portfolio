{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "portfolio",
  "author": "Paul Barnes",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "GATSBY_TELEMETRY_DISABLED=1 GATSBY_FEEDBACK_DISABLED=1 gatsby develop",
    "start": "npm run develop",
    "build": "GATSBY_TELEMETRY_DISABLED=1 GATSBY_FEEDBACK_DISABLED=1 gatsby build",
    "deploy": "npm run build && AWS_SDK_LOAD_CONFIG=1 node scripts/deploy-s3.js",
    "serve": "gatsby serve",
    "clean": "GATSBY_TELEMETRY_DISABLED=1 GATSBY_FEEDBACK_DISABLED=1 gatsby clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws-sdk": "^2.1550.0",
    "classnames": "^2.5.1",
    "gatsby": "^5.13.2",
    "gatsby-plugin-google-analytics": "^5.13.1",
    "gatsby-plugin-react-helmet": "^6.13.1",
    "gatsby-plugin-sharp": "^5.13.1",
    "gatsby-remark-images": "^7.14.0",
    "gatsby-remark-prismjs": "^7.14.0",
    "gatsby-source-filesystem": "^5.13.1",
    "gatsby-transformer-javascript-static-exports": "^5.13.1",
    "gatsby-transformer-json": "^5.13.1",
    "gatsby-transformer-remark": "^6.14.0",
    "gatsby-transformer-sharp": "^5.13.1",
    "gsap": "^2.0.1",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.70.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "gatsby-plugin-sass": "^6.13.1",
    "typescript": "^5.3.3"
  }
}
